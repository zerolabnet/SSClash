### Module config.js — Reload config / Restart core ###

msgid "Reload configuration via Mihomo API — active connections are preserved. Firewall rules are NOT rebuilt; use \"Save & Restart core\" when changing external-controller / tproxy-port / tun / fake-ip-filter-mode / proxy mode."
msgstr "Reload configuration via Mihomo API — active connections are preserved. Firewall rules are NOT rebuilt; use \"Save & Restart core\" when changing external-controller / tproxy-port / tun / fake-ip-filter-mode / proxy mode."

msgid "Full restart: stops and starts the Mihomo core, rebuilds firewall rules and refreshes subscription IPs. Active connections are dropped."
msgstr "Full restart: stops and starts the Mihomo core, rebuilds firewall rules and refreshes subscription IPs. Active connections are dropped."

msgid "Service is not running — config reload requires a running Mihomo instance. Use \"Save & Restart core\" instead."
msgstr "Service is not running — config reload requires a running Mihomo instance. Use \"Save & Restart core\" instead."

msgid "Config reload failed (%s, HTTP %s). %s Try \"Save & Restart core\" for a full restart."
msgstr "Config reload failed (%s, HTTP %s). %s Try \"Save & Restart core\" for a full restart."

msgid "(Hint: the system curl has no HTTPS support. Install curl-ssl, or use plain external-controller for hot reload.)"
msgstr "(Hint: the system curl has no HTTPS support. Install curl-ssl, or use plain external-controller for hot reload.)"

msgid "Config reloaded, but updating subscription IP cache failed: %s"
msgstr "Config reloaded, but updating subscription IP cache failed: %s"

msgid "Config reloaded via Mihomo API — active connections preserved."
msgstr "Config reloaded via Mihomo API — active connections preserved."

msgid "Config reload error: %s. Try \"Save & Restart core\" for a full restart."
msgstr "Config reload error: %s. Try \"Save & Restart core\" for a full restart."

